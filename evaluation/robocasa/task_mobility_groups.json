{
    "version": 1,
    "source": "robocasa/robocasa/environments/kitchen/atomic",
    "notes": {
        "must_move_base": "Tasks whose success condition explicitly depends on mobile base position or orientation.",
        "guaranteed_no_base_motion": "Conservative subset of single-station tasks that do not check base pose in success and are intended to be completed near the initialized fixture.",
        "likely_no_base_motion": "Tasks that do not explicitly require base motion in success, but may span multiple fixtures or depend on layout reachability."
    },
    "default_eval_group": "guaranteed_no_base_motion",
